/*
 * Termux Application - Java Application Build Script
 * This is a Java application, NOT an Android app
 */

// ============================================
// PLUGINS
// ============================================
plugins {
    // Java application plugin
    id 'application'
    
    // Checkstyle for code quality
    id 'checkstyle'
    
    // Shadow plugin for fat JAR (optional but recommended)
    id 'com.github.johnrengelman.shadow' version '8.1.1' apply false
}

// ============================================
// PROJECT METADATA
// ============================================
group = 'com.termux'
version = '1.0.0-SNAPSHOT'
description = 'Termux Application - Android terminal emulator and Linux environment'

// ============================================
// JAVA COMPATIBILITY
// ============================================
java {
    sourceCompatibility = JavaVersion.VERSION_11
    targetCompatibility = JavaVersion.VERSION_11
}

// ============================================
// APPLICATION CONFIGURATION
// ============================================
application {
    mainClass = 'com.termux.Main'
    applicationName = 'termux-app'
    
    applicationDefaultJvmArgs = [
        '-Xms256m',
        '-Xmx1024m',
        '-Dfile.encoding=UTF-8'
    ]
}

// ============================================
// REPOSITORIES
// ============================================
repositories {
    mavenCentral()
    google()  // For Firebase dependencies
    maven {
        url 'https://jitpack.io'
    }
}

// ============================================
// DEPENDENCIES
// ============================================
dependencies {
    // ===== FIREBASE (Java SDK, not Android SDK) =====
    // Firebase Admin SDK for server-side Java applications
    implementation 'com.google.firebase:firebase-admin:9.2.0'
    
    // Firebase Authentication
    implementation 'com.google.firebase:firebase-auth:22.3.0'
    
    // Firebase Cloud Firestore
    implementation 'com.google.cloud:google-cloud-firestore:3.13.2'
    
    // Google Cloud Storage (if needed)
    implementation 'com.google.cloud:google-cloud-storage:2.30.0'
    
    // ===== CORE Dependencies =====
    implementation 'com.google.code.findbugs:jsr305:3.0.2'
    implementation 'org.apache.commons:commons-lang3:3.14.0'
    implementation 'com.google.guava:guava:33.0.0-jre'
    
    // ===== LOGGING =====
    implementation 'org.slf4j:slf4j-api:2.0.11'
    implementation 'org.slf4j:slf4j-simple:2.0.11'
    
    // ===== JSON PROCESSING =====
    implementation 'com.google.code.gson:gson:2.10.1'
    implementation 'com.fasterxml.jackson.core:jackson-databind:2.16.1'
    
    // ===== HTTP CLIENT =====
    implementation 'com.squareup.okhttp3:okhttp:4.12.0'
    
    // ===== TEST Dependencies =====
    testImplementation 'junit:junit:4.13.2'
    testImplementation 'org.junit.jupiter:junit-jupiter-api:5.10.2'
    testRuntimeOnly 'org.junit.jupiter:junit-jupiter-engine:5.10.2'
    testRuntimeOnly 'org.junit.vintage:junit-vintage-engine:5.10.2'
    testImplementation 'org.mockito:mockito-core:5.10.0'
    testImplementation 'org.assertj:assertj-core:3.25.3'
}

// ============================================
// TEST CONFIGURATION
// ============================================
test {
    useJUnitPlatform()
    
    testLogging {
        events = ['passed', 'skipped', 'failed']
        showExceptions = true
        showStackTraces = true
        showCauses = true
        exceptionFormat = 'full'
    }
    
    maxHeapSize = '512m'
    
    reports {
        html.required = true
        junitXml.required = true
    }
}

// ============================================
// JAR CONFIGURATION
// ============================================
jar {
    manifest {
        attributes(
            'Implementation-Title': project.name,
            'Implementation-Version': project.version,
            'Implementation-Vendor': 'Termux Community',
            'Main-Class': application.mainClass,
            'Build-Timestamp': new Date().format('yyyy-MM-dd HH:mm:ss'),
            'Build-Jdk': System.properties['java.version']
        )
    }
    
    exclude 'META-INF/*.SF'
    exclude 'META-INF/*.DSA'
    exclude 'META-INF/*.RSA'
}

// ============================================
// CHECKSTYLE CONFIGURATION (FIXED)
// ============================================
checkstyle {
    toolVersion = '10.12.7'
    showViolations = true
    maxErrors = 100
    
    // FIXED: Removed the problematic 'exclude' line
    // Configuration file
    configFile = file("${rootDir}/config/checkstyle/checkstyle.xml")
    
    // Only create if it doesn't exist
    if (!configFile.exists()) {
        configFile.parentFile.mkdirs()
        configFile.text = """<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <module name="TreeWalker">
        <module name="Indentation"/>
        <module name="LineLength">
            <property name="max" value="120"/>
        </module>
        <module name="MethodName"/>
        <module name="TypeName"/>
        <module name="PackageName"/>
        <module name="ParameterName"/>
        <module name="LocalVariableName"/>
        <module name="ConstantName"/>
        <module name="UnusedImports"/>
        <module name="RedundantImport"/>
    </module>
</module>"""
    }
}

// ============================================
// TASKS
// ============================================
tasks.register('setupFirebase') {
    description = 'Sets up Firebase configuration'
    group = 'firebase'
    
    doLast {
        println """
╔══════════════════════════════════════════════════════════╗
║  🔥 FIREBASE SETUP FOR JAVA APPLICATION                 ║
║                                                          ║
║  This is a Java application, not an Android app.        ║
║  Firebase integration requires the Admin SDK.          ║
║                                                          ║
║  Steps:                                                 ║
║  1. Go to Firebase Console                              ║
║  2. Create a Service Account:                           ║
║     Project Settings -> Service Accounts                ║
║  3. Generate a new private key (JSON)                   ║
║  4. Place the JSON file in: src/main/resources/        ║
║  5. Set environment variable:                           ║
║     GOOGLE_APPLICATION_CREDENTIALS=path/to/key.json    ║
║                                                          ║
║  For more info:                                         ║
║  https://firebase.google.com/docs/admin/setup          ║
╚══════════════════════════════════════════════════════════╝
"""
    }
}

// ============================================
// WRAPPER CONFIGURATION
// ============================================
wrapper {
    distributionType = Wrapper.DistributionType.ALL
    gradleVersion = '8.5'
}

// ============================================
// DEFAULT TASKS
// ============================================
defaultTasks 'clean', 'build'

// ============================================
// PROJECT INFO
// ============================================
println """
Building ${project.name} v${project.version}
Java: ${JavaVersion.current()}
Gradle: ${gradle.gradleVersion}
"""